# WriteRight AI Worker — Environment Variables
# Copy this file to .env and fill in your values.

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Supabase (use service role key — bypasses RLS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# Google AI Studio (LLM API)
GOOGLE_AI_STUDIO_API_KEY=your-google-api-key
GOOGLE_AI_STUDIO_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
DEFAULT_MODEL=gemini-2.5-flash

# Task-specific model overrides (JSON)
# TASK_MODEL_MAP={"write_improvement": "anthropic/claude-3.5-sonnet"}

# Worker settings
WORKER_CONCURRENCY=4
WORKER_POLL_INTERVAL_MS=500
JOB_MAX_RETRIES=3
JOB_TIMEOUT_SECONDS=30

# Token limits
MAX_INPUT_TOKENS=4096
MAX_OUTPUT_TOKENS=2048

# Observability (optional — leave empty to disable tracing)
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=writeright-worker
